pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Pulling code from GitHub'
            }
        }

        stage('Build') {
            steps {
                echo 'Build successful'
            }
        }

        stage('Test') {
            steps {
                echo 'Tests successful'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Ready for deployment'
            }
        }
    }
}
